# Polycom TC8 (codename proline_exec / EXEC PROTO3)
TARGET_NAME=tc8-proline_exec
SOC=imx8mm
SOC_VARIANT=quad
DRAM_TYPE=lpddr4
DRAM_SIZE_GB=2
DEFCONFIG=polycom_proline_exec_defconfig
DTS=imx8mm-polycom-proline-exec
STOCK_UBOOT_REF=/var/lib/vz/dump/tc8-backup/emmc.img@0x8400   # offset within eMMC dump
