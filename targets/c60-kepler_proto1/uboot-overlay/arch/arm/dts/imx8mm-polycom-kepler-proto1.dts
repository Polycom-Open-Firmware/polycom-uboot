/*
 * Polycom Trio C60 (codename kepler_proto1) — u-boot minimal DTS
 *
 * Derived from arch/arm/dts/imx8mm-evk.dts (NXP EVK reference) with C60
 * specifics:
 *   - 2 GiB LPDDR4 (vs EVK 1 GiB / 2 GiB variant)
 *   - PMIC: Rohm BD71837 @ i2c1 0x4b  (EVK uses PCA9450 @ 0x25)
 *   - usdhc3 (eMMC) — same pads/pinmux as EVK (verified byte-for-byte)
 *   - uart2 console — same pads/pinmux as EVK
 *
 * The kernel-side DTS lives in c60-firmware-build (richer: panel, audio,
 * WiFi, mic array). This one only has what u-boot needs to enumerate
 * eMMC, talk to UART2, and reach fastboot.
 */

/dts-v1/;

#include <dt-bindings/usb/pd.h>
#include <dt-bindings/gpio/gpio.h>
#include "imx8mm.dtsi"

/ {
	model = "Polycom Trio C60 (kepler_proto1)";
	compatible = "polycom,kepler-proto1", "fsl,imx8mm";

	chosen {
		stdout-path = &uart2;
	};

	memory@40000000 {
		device_type = "memory";
		reg = <0x0 0x40000000 0 0x80000000>;
	};

	aliases {
		mmc0 = &usdhc3;        /* eMMC */
		serial0 = &uart2;      /* console */
		usbgadget0 = &usbg1;
	};

	/*
	 * DM USB-gadget binding node. The ci-udc-otg driver
	 * (UCLASS_USB_GADGET_GENERIC) only binds to compatible
	 * "fsl,imx27-usb-gadget" with a chipidea,usb phandle. NXP supply
	 * this via imx8mm-evk-u-boot.dtsi; our standalone DTS has no
	 * matching -u-boot.dtsi, so without this node fastboot/ums fail
	 * with "No USB device found / USB init failed: -19". This is the
	 * single node that makes the gadget controller enumerate.
	 */
	usbg1: usbg1 {
		compatible = "fsl,imx27-usb-gadget";
		dr_mode = "peripheral";
		chipidea,usb = <&usbotg1>;
		status = "okay";
	};
};

&i2c1 {
	clock-frequency = <100000>;
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_i2c1>;
	status = "okay";

	pmic@4b {
		compatible = "rohm,bd71837";
		reg = <0x4b>;
		/* the BD71837 driver in u-boot doesn't require child regulators
		 * to be enumerated for boot-time use; SPL hits it via the
		 * legacy power_bd71837_init() path. */
	};
};

&i2c2 {
	clock-frequency = <400000>;
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_i2c2>;
	status = "okay";

	/* FocalTech FT5x46-class touch controller @ 0x38. No u-boot touch
	 * driver binds here; the c60_touch board command drives the reset
	 * GPIO (SD1_DATA1) and reads the touch-report registers over this
	 * bus so a finger press can gate boot selection. Also the CENTRE
	 * LP5569 light-bar controller @ 0x32 (driven raw by the c60_ledbar
	 * board code — no u-boot LED driver binds). */
};

/* Light-bar side controllers. The 3 LP5569s live one-per-bus: centre on
 * i2c2 (above), left on i2c3, right on i2c4, all @ 0x32. Enable the two
 * side buses so the bootsel code can reach them over raw DM-I2C. */
&i2c3 {
	clock-frequency = <400000>;
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_i2c3>;
	status = "okay";
};

&i2c4 {
	clock-frequency = <400000>;
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_i2c4>;
	status = "okay";
};

&uart2 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_uart2>;
	status = "okay";
};

&usdhc3 {
	assigned-clocks = <&clk IMX8MM_CLK_USDHC3_ROOT>;
	assigned-clock-rates = <400000000>;
	pinctrl-names = "default", "state_100mhz", "state_200mhz";
	pinctrl-0 = <&pinctrl_usdhc3>;
	pinctrl-1 = <&pinctrl_usdhc3_100mhz>;
	pinctrl-2 = <&pinctrl_usdhc3_200mhz>;
	bus-width = <8>;
	non-removable;
	status = "okay";
};

&usbotg1 {
	/*
	 * Force peripheral mode. The EVK uses dr_mode="otg" + usb-role-switch
	 * + a USB-C TCPC (PTN5110) to pick host/device at runtime. The C60
	 * has no TCPC, so with "otg" the ehci-mx6 driver never registers a
	 * UCLASS_USB_GADGET_GENERIC device and fastboot/ums fail with
	 * "No USB device found / -19". Hard-wiring "peripheral" makes the
	 * controller always bind as a gadget — exactly what we need for the
	 * fastboot-based slot flashing + uuu workflow.
	 */
	dr_mode = "peripheral";
	srp-disable;
	hnp-disable;
	adp-disable;
	power-active-high;
	disable-over-current;
	status = "okay";
};

&iomuxc {
	pinctrl_i2c1: i2c1grp {
		fsl,pins = <
			MX8MM_IOMUXC_I2C1_SCL_I2C1_SCL                  0x400001c3
			MX8MM_IOMUXC_I2C1_SDA_I2C1_SDA                  0x400001c3
		>;
	};

	pinctrl_i2c2: i2c2grp {
		fsl,pins = <
			MX8MM_IOMUXC_I2C2_SCL_I2C2_SCL                  0x400001c3
			MX8MM_IOMUXC_I2C2_SDA_I2C2_SDA                  0x400001c3
		>;
	};

	/* Light-bar side buses (values verified against stock c60.dts). */
	pinctrl_i2c3: i2c3grp {
		fsl,pins = <
			MX8MM_IOMUXC_I2C3_SCL_I2C3_SCL                  0x400001c3
			MX8MM_IOMUXC_I2C3_SDA_I2C3_SDA                  0x400001c3
		>;
	};

	pinctrl_i2c4: i2c4grp {
		fsl,pins = <
			MX8MM_IOMUXC_I2C4_SCL_I2C4_SCL                  0x400001c3
			MX8MM_IOMUXC_I2C4_SDA_I2C4_SDA                  0x400001c3
		>;
	};

	pinctrl_uart2: uart2grp {
		fsl,pins = <
			MX8MM_IOMUXC_UART2_RXD_UART2_DCE_RX             0x140
			MX8MM_IOMUXC_UART2_TXD_UART2_DCE_TX             0x140
		>;
	};

	/* Same byte values as EVK — verified against stock C60 DTS */
	pinctrl_usdhc3: usdhc3grp {
		fsl,pins = <
			MX8MM_IOMUXC_NAND_WE_B_USDHC3_CLK               0x190
			MX8MM_IOMUXC_NAND_WP_B_USDHC3_CMD               0x1d0
			MX8MM_IOMUXC_NAND_DATA04_USDHC3_DATA0           0x1d0
			MX8MM_IOMUXC_NAND_DATA05_USDHC3_DATA1           0x1d0
			MX8MM_IOMUXC_NAND_DATA06_USDHC3_DATA2           0x1d0
			MX8MM_IOMUXC_NAND_DATA07_USDHC3_DATA3           0x1d0
			MX8MM_IOMUXC_NAND_RE_B_USDHC3_DATA4             0x1d0
			MX8MM_IOMUXC_NAND_CE2_B_USDHC3_DATA5            0x1d0
			MX8MM_IOMUXC_NAND_CE3_B_USDHC3_DATA6            0x1d0
			MX8MM_IOMUXC_NAND_CLE_USDHC3_DATA7              0x1d0
			MX8MM_IOMUXC_NAND_CE1_B_USDHC3_STROBE           0x190
		>;
	};
	pinctrl_usdhc3_100mhz: usdhc3-100mhzgrp {
		fsl,pins = <
			MX8MM_IOMUXC_NAND_WE_B_USDHC3_CLK               0x194
			MX8MM_IOMUXC_NAND_WP_B_USDHC3_CMD               0x1d4
			MX8MM_IOMUXC_NAND_DATA04_USDHC3_DATA0           0x1d4
			MX8MM_IOMUXC_NAND_DATA05_USDHC3_DATA1           0x1d4
			MX8MM_IOMUXC_NAND_DATA06_USDHC3_DATA2           0x1d4
			MX8MM_IOMUXC_NAND_DATA07_USDHC3_DATA3           0x1d4
			MX8MM_IOMUXC_NAND_RE_B_USDHC3_DATA4             0x1d4
			MX8MM_IOMUXC_NAND_CE2_B_USDHC3_DATA5            0x1d4
			MX8MM_IOMUXC_NAND_CE3_B_USDHC3_DATA6            0x1d4
			MX8MM_IOMUXC_NAND_CLE_USDHC3_DATA7              0x1d4
			MX8MM_IOMUXC_NAND_CE1_B_USDHC3_STROBE           0x194
		>;
	};
	pinctrl_usdhc3_200mhz: usdhc3-200mhzgrp {
		fsl,pins = <
			MX8MM_IOMUXC_NAND_WE_B_USDHC3_CLK               0x196
			MX8MM_IOMUXC_NAND_WP_B_USDHC3_CMD               0x1d6
			MX8MM_IOMUXC_NAND_DATA04_USDHC3_DATA0           0x1d6
			MX8MM_IOMUXC_NAND_DATA05_USDHC3_DATA1           0x1d6
			MX8MM_IOMUXC_NAND_DATA06_USDHC3_DATA2           0x1d6
			MX8MM_IOMUXC_NAND_DATA07_USDHC3_DATA3           0x1d6
			MX8MM_IOMUXC_NAND_RE_B_USDHC3_DATA4             0x1d6
			MX8MM_IOMUXC_NAND_CE2_B_USDHC3_DATA5            0x1d6
			MX8MM_IOMUXC_NAND_CE3_B_USDHC3_DATA6            0x1d6
			MX8MM_IOMUXC_NAND_CLE_USDHC3_DATA7              0x1d6
			MX8MM_IOMUXC_NAND_CE1_B_USDHC3_STROBE           0x196
		>;
	};
};

/*
 * ===========================================================================
 * Display: LCDIF -> Samsung MIPI-DSIM -> RM67191-class 720x1280 panel.
 *
 * Ports the shipped Linux v0.1.7 bring-up (c60-kernel-patches 0001/0012) onto
 * u-boot's proven sec_mipi_dsim + mxsfb + video_link path. Structure mirrors
 * the working TC8 stage-2 DTS (imx8mm-polycom-proline-exec.dts) — which
 * documents every gotcha for this exact u-boot video stack:
 *   - panel is a TOP-LEVEL node (u-boot video_link only chains DM-bound
 *     top-level udevices; a &mipi_dsi child is never bound, so its
 *     get_display_timing()/enable never run);
 *   - the UCLASS_DSI_HOST back-end is a SEPARATE top-level "dsi-host" node;
 *   - &mipi_dsi keeps the base "fsl,imx8mm-mipi-dsim" compatible (binds the
 *     imx_sec_dsim VIDEO_BRIDGE that mxsfb actually drives);
 *   - &lcdif must carry `display = <&display0>` + bits-per-pixel or mxsfb
 *     refuses to probe ("required display property isn't provided").
 * C60 specifics vs TC8: 720x1280 @ 79.61 MHz (not 800x1280/76.5 MHz),
 * non-burst SYNC-PULSE (video-mode=2; burst gave wrong colours per the RE),
 * panel power-enable gpio2_4, reset gpio2_5, PWM4 backlight on SAI3_MCLK.
 * ===========================================================================
 */
/ {
	backlight: backlight {
		compatible = "pwm-backlight";
		pwms = <&pwm4 0 100000 0>;         /* stock 100 us period = 10 kHz */
		brightness-levels = <0 255>;
		num-interpolated-steps = <255>;
		default-brightness-level = <250>;  /* stock 0xfa */
		status = "okay";
	};

	c60_panel: c60-panel {
		compatible = "poly,kepler-c60";
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_disp_ctrl>;
		power-gpio = <&gpio2 4 GPIO_ACTIVE_HIGH>;  /* panel 3.3V enable */
		reset-gpio = <&gpio2 5 GPIO_ACTIVE_LOW>;   /* panel reset */
		dsi-lanes = <4>;
		video-mode = <2>;                          /* non-burst sync-pulse */
		backlight = <&backlight>;
		status = "okay";

		port {
			c60_from_dsim: endpoint {
				remote-endpoint = <&dsim_to_c60>;
			};
		};
	};

	dsi_host: dsi-host {
		compatible = "samsung,sec-mipi-dsi";
		status = "okay";
	};
};

&lcdif {
	display = <&display0>;
	status = "okay";

	display0: display@0 {
		bits-per-pixel = <24>;
		bus-width = <24>;

		display-timings {
			native-mode = <&timing_c60>;
			timing_c60: timing-c60 {
				clock-frequency = <79610000>;
				hactive = <720>;
				vactive = <1280>;
				hfront-porch = <100>;
				hback-porch = <30>;
				hsync-len = <90>;
				vfront-porch = <16>;
				vback-porch = <2>;
				vsync-len = <5>;
				hsync-active = <0>;   /* NHSYNC */
				vsync-active = <0>;   /* NVSYNC */
				de-active = <0>;      /* DE low */
				pixelclk-active = <1>;
			};
		};
	};
};

&mipi_dsi {
	status = "okay";

	port@1 {
		dsim_to_c60: endpoint {
			remote-endpoint = <&c60_from_dsim>;
		};
	};
};

&pwm4 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_pwm4>;
	status = "okay";
};

&iomuxc {
	/* panel power-enable (gpio2_4) + reset (gpio2_5); GPIO mode, pad-ctl 0x16 */
	pinctrl_disp_ctrl: dispctrlgrp {
		fsl,pins = <
			MX8MM_IOMUXC_SD1_DATA2_GPIO2_IO4        0x16
			MX8MM_IOMUXC_SD1_DATA3_GPIO2_IO5        0x16
		>;
	};
	/* PWM4_OUT on SAI3_MCLK, ALT1, pad-ctl 0xd6 (stock; &sai3 left disabled) */
	pinctrl_pwm4: pwm4grp {
		fsl,pins = <
			MX8MM_IOMUXC_SAI3_MCLK_PWM4_OUT         0xd6
		>;
	};
};
