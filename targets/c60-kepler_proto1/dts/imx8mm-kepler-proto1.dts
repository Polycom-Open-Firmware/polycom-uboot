/dts-v1/;

/ {
	compatible = "fsl,imx8mm-kepler-proto1\0fsl,imx8mm";
	interrupt-parent = <0x01>;
	#address-cells = <0x02>;
	#size-cells = <0x02>;
	model = "FSL i.MX8MM Kepler proto1 board";

	cpus {
		#address-cells = <0x02>;
		#size-cells = <0x00>;

		idle-states {
			entry-method = "psci";

			cpu-sleep {
				compatible = "arm,idle-state";
				local-timer-stop;
				arm,psci-suspend-param = <0x10033>;
				entry-latency-us = <0x3e8>;
				exit-latency-us = <0x2bc>;
				min-residency-us = <0xa8c>;
				wakeup-latency-us = <0x5dc>;
				phandle = <0x03>;
			};

			cluster-sleep {
				compatible = "arm,idle-state";
				local-timer-stop;
				arm,psci-suspend-param = <0x1000000>;
				entry-latency-us = <0x3e8>;
				exit-latency-us = <0x2bc>;
				min-residency-us = <0xa8c>;
				wakeup-latency-us = <0x5dc>;
			};
		};

		cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x00 0x00>;
			enable-method = "psci";
			next-level-cache = <0x02>;
			cpu-idle-states = <0x03>;
			operating-points = <0x1b7740 0xf4240 0x186a00 0xdbba0 0x124f80 0xc3500>;
			clocks = <0x04 0x4c 0x04 0x42 0x04 0x18 0x04 0x2c 0x04 0x38>;
			clock-names = "a53\0arm_a53_src\0arm_pll\0arm_pll_out\0sys1_pll_800m";
			clock-latency = <0xee6c>;
			#cooling-cells = <0x02>;
			arm-supply = <0x05>;
			phandle = <0x09>;
		};

		cpu@1 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x00 0x01>;
			enable-method = "psci";
			next-level-cache = <0x02>;
			cpu-idle-states = <0x03>;
		};

		cpu@2 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x00 0x02>;
			enable-method = "psci";
			next-level-cache = <0x02>;
			cpu-idle-states = <0x03>;
		};

		cpu@3 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x00 0x03>;
			enable-method = "psci";
			next-level-cache = <0x02>;
			cpu-idle-states = <0x03>;
		};

		l2-cache0 {
			compatible = "cache";
			phandle = <0x02>;
		};
	};

	psci {
		compatible = "arm,psci-1.0";
		method = "smc";
		cpu_suspend = <0xc4000001>;
		cpu_off = <0xc4000002>;
		cpu_on = <0xc4000003>;
	};

	aliases {
		ethernet0 = "/ethernet@30be0000";
		i2c0 = "/i2c@30a20000";
		i2c1 = "/i2c@30a30000";
		i2c2 = "/i2c@30a40000";
		i2c3 = "/i2c@30a50000";
		serial0 = "/serial@30860000";
		serial1 = "/serial@30890000";
		serial2 = "/serial@30880000";
		gpio0 = "/gpio@30200000";
		gpio1 = "/gpio@30210000";
		gpio2 = "/gpio@30220000";
		gpio3 = "/gpio@30230000";
		gpio4 = "/gpio@30240000";
		spi0 = "/flexspi@30bb0000";
		usb0 = "/usb@32e40000";
		usb1 = "/usb@32e50000";
	};

	memory@40000000 {
		device_type = "memory";
		reg = <0x00 0x40000000 0x00 0x80000000>;
	};

	reserved-memory {
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;

		linux,cma {
			compatible = "shared-dma-pool";
			reusable;
			size = <0x00 0x28000000>;
			alloc-ranges = <0x00 0x40000000 0x00 0x80000000>;
			linux,cma-default;
		};
	};

	interrupt-controller@38800000 {
		compatible = "arm,gic-v3";
		reg = <0x00 0x38800000 0x00 0x10000 0x00 0x38880000 0x00 0xc0000>;
		#interrupt-cells = <0x03>;
		interrupt-controller;
		interrupts = <0x01 0x09 0x04>;
		interrupt-parent = <0x06>;
		phandle = <0x06>;
	};

	timer {
		compatible = "arm,armv8-timer";
		interrupts = <0x01 0x0d 0x3f08 0x01 0x0e 0x3f08 0x01 0x0b 0x3f08 0x01 0x0a 0x3f08>;
		clock-frequency = <0x7a1200>;
		interrupt-parent = <0x06>;
	};

	clocks {
		#address-cells = <0x01>;
		#size-cells = <0x00>;

		clock@0 {
			compatible = "fixed-clock";
			reg = <0x00>;
			#clock-cells = <0x00>;
			clock-frequency = <0x8000>;
			clock-output-names = "osc_32k";
			phandle = <0x0c>;
		};

		clock@1 {
			compatible = "fixed-clock";
			reg = <0x01>;
			#clock-cells = <0x00>;
			clock-frequency = <0x16e3600>;
			clock-output-names = "osc_24m";
			phandle = <0x0d>;
		};

		clock@2 {
			compatible = "fixed-clock";
			reg = <0x03>;
			#clock-cells = <0x00>;
			clock-frequency = <0x7ed6b40>;
			clock-output-names = "clk_ext1";
			phandle = <0x0e>;
		};

		clock@3 {
			compatible = "fixed-clock";
			reg = <0x04>;
			#clock-cells = <0x00>;
			clock-frequency = <0x7ed6b40>;
			clock-output-names = "clk_ext2";
			phandle = <0x0f>;
		};

		clock@4 {
			compatible = "fixed-clock";
			reg = <0x05>;
			#clock-cells = <0x00>;
			clock-frequency = <0x7ed6b40>;
			clock-output-names = "clk_ext3";
			phandle = <0x10>;
		};

		clock@5 {
			compatible = "fixed-clock";
			reg = <0x06>;
			#clock-cells = <0x00>;
			clock-frequency = <0x7ed6b40>;
			clock-output-names = "clk_ext4";
			phandle = <0x11>;
		};
	};

	gpc_power_domain@0 {
		compatible = "fsl,imx8mm-pm-domain";
		#power-domain-cells = <0x00>;
		domain-id = <0x00>;
		domain-name = "MIPI_PD";
	};

	gpc_power_domain@1 {
		compatible = "fsl,imx8mm-pm-domain";
		#power-domain-cells = <0x00>;
		domain-id = <0x01>;
		domain-name = "PCIE0_PD";
	};

	gpc_power_domain@2 {
		compatible = "fsl,imx8mm-pm-domain";
		#power-domain-cells = <0x00>;
		domain-id = <0x02>;
		domain-name = "USB_OTG1_PD";
	};

	gpc_power_domain@3 {
		compatible = "fsl,imx8mm-pm-domain";
		#power-domain-cells = <0x00>;
		domain-id = <0x03>;
		domain-name = "USB_OTG2_PD";
	};

	gpc_power_domain@4 {
		compatible = "fsl,imx8mm-pm-domain";
		#power-domain-cells = <0x00>;
		domain-id = <0x04>;
		domain-name = "GPU_2D_PD";
	};

	gpc_power_domain@5 {
		compatible = "fsl,imx8mm-pm-domain";
		#power-domain-cells = <0x00>;
		domain-id = <0x05>;
		domain-name = "GPU_MIX_PD";
	};

	gpc_power_domain@6 {
		compatible = "fsl,imx8mm-pm-domain";
		#power-domain-cells = <0x00>;
		domain-id = <0x06>;
		domain-name = "VPU_MIX_PD";
	};

	gpc_power_domain@7 {
		compatible = "fsl,imx8mm-pm-domain";
		#power-domain-cells = <0x00>;
		domain-id = <0x07>;
		domain-name = "DISP_MIX_PD";
	};

	gpc_power_domain@8 {
		compatible = "fsl,imx8mm-pm-domain";
		#power-domain-cells = <0x00>;
		domain-id = <0x08>;
		domain-name = "VPU_G1_PD";
		phandle = <0x37>;
	};

	gpc_power_domain@9 {
		compatible = "fsl,imx8mm-pm-domain";
		#power-domain-cells = <0x00>;
		domain-id = <0x09>;
		domain-name = "VPU_G2_PD";
		phandle = <0x38>;
	};

	gpc_power_domain@10 {
		compatible = "fsl,imx8mm-pm-domain";
		#power-domain-cells = <0x00>;
		domain-id = <0x0a>;
		domain-name = "VPU_H1_PD";
		phandle = <0x36>;
	};

	gpio@30200000 {
		compatible = "fsl,imx8mm-gpio\0fsl,imx35-gpio";
		reg = <0x00 0x30200000 0x00 0x10000>;
		interrupts = <0x00 0x40 0x04 0x00 0x41 0x04>;
		gpio-controller;
		#gpio-cells = <0x02>;
		interrupt-controller;
		#interrupt-cells = <0x02>;
		phandle = <0x17>;
	};

	gpio@30210000 {
		compatible = "fsl,imx8mm-gpio\0fsl,imx35-gpio";
		reg = <0x00 0x30210000 0x00 0x10000>;
		interrupts = <0x00 0x42 0x04 0x00 0x43 0x04>;
		gpio-controller;
		#gpio-cells = <0x02>;
		interrupt-controller;
		#interrupt-cells = <0x02>;
		phandle = <0x39>;
	};

	gpio@30220000 {
		compatible = "fsl,imx8mm-gpio\0fsl,imx35-gpio";
		reg = <0x00 0x30220000 0x00 0x10000>;
		interrupts = <0x00 0x44 0x04 0x00 0x45 0x04>;
		gpio-controller;
		#gpio-cells = <0x02>;
		interrupt-controller;
		#interrupt-cells = <0x02>;
	};

	gpio@30230000 {
		compatible = "fsl,imx8mm-gpio\0fsl,imx35-gpio";
		reg = <0x00 0x30230000 0x00 0x10000>;
		interrupts = <0x00 0x46 0x04 0x00 0x47 0x04>;
		gpio-controller;
		#gpio-cells = <0x02>;
		interrupt-controller;
		#interrupt-cells = <0x02>;
	};

	gpio@30240000 {
		compatible = "fsl,imx8mm-gpio\0fsl,imx35-gpio";
		reg = <0x00 0x30240000 0x00 0x10000>;
		interrupts = <0x00 0x48 0x04 0x00 0x49 0x04>;
		gpio-controller;
		#gpio-cells = <0x02>;
		interrupt-controller;
		#interrupt-cells = <0x02>;
		phandle = <0x15>;
	};

	tmu@30260000 {
		compatible = "fsl,imx8mm-tmu";
		reg = <0x00 0x30260000 0x00 0x10000>;
		interrupt = <0x00 0x31 0x04>;
		little-endian;
		u-boot,dm-pre-reloc;
		#thermal-sensor-cells = <0x00>;
		phandle = <0x07>;
	};

	thermal-zones {

		cpu-thermal {
			polling-delay-passive = <0xfa>;
			polling-delay = <0x7d0>;
			thermal-sensors = <0x07>;

			trips {

				trip0 {
					temperature = <0x14c08>;
					hysteresis = <0x7d0>;
					type = "passive";
					phandle = <0x08>;
				};

				trip1 {
					temperature = <0x17318>;
					hysteresis = <0x7d0>;
					type = "critical";
				};
			};

			cooling-maps {

				map0 {
					trip = <0x08>;
					cooling-device = <0x09 0xffffffff 0xffffffff>;
				};
			};
		};
	};

	pinctrl@30330000 {
		compatible = "fsl,imx8mm-iomuxc";
		reg = <0x00 0x30330000 0x00 0x10000>;
		pinctrl-names = "default";
		pinctrl-0 = <0x0a>;

		imx8mm-kepler-proto1 {

			hoggrp-1 {
				fsl,pins = <0x48 0x2b0 0x00 0x00 0x00 0x19>;
				phandle = <0x0a>;
			};

			focaltech_multi_touch_iogrp {
				fsl,pins = <0xac 0x314 0x00 0x05 0x00 0x1d0 0x60 0x2c8 0x00 0x00 0x00 0x19>;
			};

			fec1grp {
				fsl,pins = <0x68 0x2d0 0x00 0x00 0x00 0x03 0x6c 0x2d4 0x4c0 0x00 0x01 0x03 0x70 0x2d8 0x00 0x00 0x00 0x1f 0x74 0x2dc 0x00 0x00 0x00 0x1f 0x78 0x2e0 0x00 0x00 0x00 0x1f 0x7c 0x2e4 0x00 0x00 0x00 0x1f 0x9c 0x304 0x00 0x00 0x00 0x91 0x98 0x300 0x00 0x00 0x00 0x91 0x94 0x2fc 0x00 0x00 0x00 0x91 0x90 0x2f8 0x00 0x00 0x00 0x91 0x84 0x2ec 0x00 0x00 0x00 0x1f 0x8c 0x2f4 0x00 0x00 0x00 0x91 0x88 0x2f0 0x00 0x00 0x00 0x91 0x80 0x2e8 0x00 0x00 0x00 0x1f 0x1b4 0x41c 0x00 0x05 0x00 0x19>;
				phandle = <0x2d>;
			};

			flexspi0grp {
				fsl,pins = <0xf4 0x35c 0x00 0x01 0x00 0x1c4 0xf8 0x360 0x00 0x01 0x00 0x84 0x10c 0x374 0x00 0x01 0x00 0x84 0x110 0x378 0x00 0x01 0x00 0x84 0x114 0x37c 0x00 0x01 0x00 0x84 0x118 0x380 0x00 0x01 0x00 0x84>;
				phandle = <0x2f>;
			};

			i2c1grp {
				fsl,pins = <0x214 0x47c 0x00 0x00 0x00 0x400001c3 0x218 0x480 0x00 0x00 0x00 0x400001c3>;
				phandle = <0x13>;
			};

			i2c2grp {
				fsl,pins = <0x21c 0x484 0x00 0x00 0x00 0x400001c3 0x220 0x488 0x00 0x00 0x00 0x400001c3>;
				phandle = <0x18>;
			};

			i2c3grp {
				fsl,pins = <0x224 0x48c 0x00 0x00 0x00 0x400001c3 0x228 0x490 0x00 0x00 0x00 0x400001c3>;
				phandle = <0x1a>;
			};

			i2c1grp-gpio {
				fsl,pins = <0x214 0x47c 0x00 0x05 0x00 0x1c3 0x218 0x480 0x00 0x05 0x00 0x1c3>;
				phandle = <0x14>;
			};

			i2c2grp-gpio {
				fsl,pins = <0x21c 0x484 0x00 0x05 0x00 0x1c3 0x220 0x488 0x00 0x05 0x00 0x1c3>;
				phandle = <0x19>;
			};

			i2c3grp-gpio {
				fsl,pins = <0x224 0x48c 0x00 0x05 0x00 0x1c3 0x228 0x490 0x00 0x05 0x00 0x1c3>;
				phandle = <0x1b>;
			};

			pmicirq {
				fsl,pins = <0x34 0x29c 0x00 0x00 0x00 0x41>;
				phandle = <0x16>;
			};

			uart1grp {
				fsl,pins = <0x23c 0x4a4 0x4fc 0x00 0x00 0x49 0x240 0x4a8 0x00 0x00 0x00 0x49>;
				phandle = <0x12>;
			};

			usdhc2grpgpio {
				fsl,pins = <0xec 0x354 0x00 0x05 0x00 0x41>;
				phandle = <0x23>;
			};

			usdhc2grp {
				fsl,pins = <0xd4 0x33c 0x00 0x00 0x00 0x190 0xd8 0x340 0x00 0x00 0x00 0x1d0 0xdc 0x344 0x00 0x00 0x00 0x1d0 0xe0 0x348 0x00 0x00 0x00 0x1d0 0xe4 0x34c 0x00 0x00 0x00 0x1d0 0xe8 0x350 0x00 0x00 0x00 0x1d0 0x38 0x2a0 0x00 0x01 0x00 0x1d0>;
				phandle = <0x22>;
			};

			usdhc2grp100mhz {
				fsl,pins = <0xd4 0x33c 0x00 0x00 0x00 0x194 0xd8 0x340 0x00 0x00 0x00 0x1d4 0xdc 0x344 0x00 0x00 0x00 0x1d4 0xe0 0x348 0x00 0x00 0x00 0x1d4 0xe4 0x34c 0x00 0x00 0x00 0x1d4 0xe8 0x350 0x00 0x00 0x00 0x1d4 0x38 0x2a0 0x00 0x01 0x00 0x1d0>;
				phandle = <0x24>;
			};

			usdhc2grp200mhz {
				fsl,pins = <0xd4 0x33c 0x00 0x00 0x00 0x196 0xd8 0x340 0x00 0x00 0x00 0x1d6 0xdc 0x344 0x00 0x00 0x00 0x1d6 0xe0 0x348 0x00 0x00 0x00 0x1d6 0xe4 0x34c 0x00 0x00 0x00 0x1d6 0xe8 0x350 0x00 0x00 0x00 0x1d6 0x38 0x2a0 0x00 0x01 0x00 0x1d0>;
				phandle = <0x25>;
			};

			usdhc3grp {
				fsl,pins = <0x138 0x3a0 0x00 0x12 0x00 0x40000190 0x13c 0x3a4 0x00 0x02 0x00 0x1d0 0x11c 0x384 0x00 0x02 0x00 0x1d0 0x120 0x388 0x00 0x02 0x00 0x1d0 0x124 0x38c 0x00 0x02 0x00 0x1d0 0x128 0x390 0x00 0x02 0x00 0x1d0 0x130 0x398 0x00 0x02 0x00 0x1d0 0x100 0x368 0x00 0x02 0x00 0x1d0 0x104 0x36c 0x00 0x02 0x00 0x1d0 0x108 0x370 0x00 0x02 0x00 0x1d0 0xfc 0x364 0x00 0x02 0x00 0x190>;
				phandle = <0x27>;
			};

			usdhc3grp100mhz {
				fsl,pins = <0x138 0x3a0 0x00 0x12 0x00 0x40000194 0x13c 0x3a4 0x00 0x02 0x00 0x1d4 0x11c 0x384 0x00 0x02 0x00 0x1d4 0x120 0x388 0x00 0x02 0x00 0x1d4 0x124 0x38c 0x00 0x02 0x00 0x1d4 0x128 0x390 0x00 0x02 0x00 0x1d4 0x130 0x398 0x00 0x02 0x00 0x1d4 0x100 0x368 0x00 0x02 0x00 0x1d4 0x104 0x36c 0x00 0x02 0x00 0x1d4 0x108 0x370 0x00 0x02 0x00 0x1d4 0xfc 0x364 0x00 0x02 0x00 0x194>;
				phandle = <0x28>;
			};

			usdhc3grp200mhz {
				fsl,pins = <0x138 0x3a0 0x00 0x12 0x00 0x40000196 0x13c 0x3a4 0x00 0x02 0x00 0x1d6 0x11c 0x384 0x00 0x02 0x00 0x1d6 0x120 0x388 0x00 0x02 0x00 0x1d6 0x124 0x38c 0x00 0x02 0x00 0x1d6 0x128 0x390 0x00 0x02 0x00 0x1d6 0x130 0x398 0x00 0x02 0x00 0x1d6 0x100 0x368 0x00 0x02 0x00 0x1d6 0x104 0x36c 0x00 0x02 0x00 0x1d6 0x108 0x370 0x00 0x02 0x00 0x1d6 0xfc 0x364 0x00 0x02 0x00 0x196>;
				phandle = <0x29>;
			};

			wdoggrp {
				fsl,pins = <0x30 0x298 0x00 0x01 0x00 0xc6>;
				phandle = <0x2b>;
			};
		};
	};

	iomuxc-gpr@30340000 {
		compatible = "fsl,imx8mm-iomuxc-gpr\0fsl,imx7d-iomuxc-gpr\0syscon";
		reg = <0x00 0x30340000 0x00 0x10000>;
		phandle = <0x2c>;
	};

	anatop@30360000 {
		compatible = "fsl,imx8mm-anatop\0syscon\0simple-bus";
		reg = <0x00 0x30360000 0x00 0x10000>;
	};

	snvs@30370000 {
		compatible = "fsl,sec-v4.0-mon\0syscon\0simple-mfd";
		reg = <0x00 0x30370000 0x00 0x10000>;
		phandle = <0x0b>;

		snvs-rtc-lp {
			compatible = "fsl,sec-v4.0-mon-rtc-lp";
			regmap = <0x0b>;
			offset = <0x34>;
			interrupts = <0x00 0x13 0x04 0x00 0x14 0x04>;
		};

		snvs-powerkey {
			compatible = "fsl,sec-v4.0-pwrkey";
			regmap = <0x0b>;
			interrupts = <0x00 0x04 0x04>;
			linux,keycode = <0x74>;
			wakeup-source;
		};
	};

	clock-controller@30380000 {
		compatible = "fsl,imx8mm-ccm";
		reg = <0x00 0x30380000 0x00 0x10000>;
		#clock-cells = <0x01>;
		clocks = <0x0c 0x0d 0x0e 0x0f 0x10 0x11>;
		clock-names = "osc_32k\0osc_24m\0clk_ext1\0clk_ext2\0clk_ext3\0clk_ext4";
		phandle = <0x04>;
	};

	src@30390000 {
		compatible = "fsl,imx8mm-src\0fsl,imx8mq-src\0syscon";
		reg = <0x00 0x30390000 0x00 0x10000>;
		interrupts = <0x00 0x59 0x04>;
		#reset-cells = <0x01>;
		phandle = <0x33>;
	};

	gpc@303a0000 {
		compatible = "fsl,imx8mm-gpc\0fsl,imx8mq-gpc\0syscon";
		reg = <0x00 0x303a0000 0x00 0x10000>;
		interrupt-controller;
		interrupts = <0x00 0x57 0x04>;
		#interrupt-cells = <0x03>;
		interrupt-parent = <0x06>;
		phandle = <0x01>;
	};

	timer@306a0000 {
		compatible = "nxp,sysctr-timer";
		reg = <0x00 0x306a0000 0x00 0x10000 0x00 0x306b0000 0x00 0x10000 0x00 0x306c0000 0x00 0x10000>;
		clock-frequency = <0x7a1200>;
