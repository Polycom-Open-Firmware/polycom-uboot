		phy-handle = <0x2e>;
		fsl,magic-packet;

		mdio {
			#address-cells = <0x01>;
			#size-cells = <0x00>;

			ethernet-phy@0 {
				compatible = "ethernet-phy-ieee802.3-c22";
				reg = <0x00>;
				at803x,led-act-blind-workaround;
				at803x,eee-okay;
				at803x,vddio-1p8v;
				phandle = <0x2e>;
			};
		};
	};

	flexspi@30bb0000 {
		#address-cells = <0x01>;
		#size-cells = <0x00>;
		compatible = "fsl,imx8qm-flexspi";
		reg = <0x00 0x30bb0000 0x00 0x10000 0x00 0x8000000 0x00 0x19ffffff>;
		reg-names = "FlexSPI\0FlexSPI-memory";
		interrupts = <0x00 0x6b 0x04>;
		clocks = <0x04 0x193 0x04 0x193>;
		clock-names = "qspi_en\0qspi";
		status = "okay";
		pinctrl-names = "default";
		pinctrl-0 = <0x2f>;

		n25q256a@0 {
			reg = <0x00>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			compatible = "spi-flash";
			spi-max-frequency = <0x1ba8140>;
			spi-nor,ddr-quad-read-dummy = <0x08>;
		};
	};

	dma_cap {
		compatible = "dma-capability";
		only-dma-mask32 = <0x01>;
	};

	imx_ion {
		compatible = "fsl,mxc-ion";
		fsl,heap-id = <0x00>;
	};

	lcdif@32E00000 {
		compatible = "fsl,imx8mm-lcdif\0fsl,imx28-lcdif";
		reg = <0x00 0x32e00000 0x00 0x10000>;
		clocks = <0x04 0x151>;
		clock-names = "pix";
		assigned-clocks = <0x04 0x9a>;
		assigned-clock-parents = <0x04 0x28>;
		assigned-clock-rate = <0x2367b880>;
		interrupts = <0x00 0x05 0x04>;
		max-res = <0x780 0x438>;
		status = "disabled";

		port@0 {

			mipi-dsi-endpoint {
				remote-endpoint = <0x30>;
				phandle = <0x35>;
			};
		};
	};

	dsi_phy@32e10300 {
		compatible = "mixel,imx8mm-mipi-dsi-phy\0mixel,imx8mq-mipi-dsi-phy";
		reg = <0x00 0x32e10300 0x00 0x100>;
		#phy-cells = <0x00>;
		status = "disabled";
		phandle = <0x31>;
	};

	mipi_dsi_bridge@32E10000 {
		compatible = "nwl,mipi-dsi";
		reg = <0x00 0x32e10000 0x00 0x400>;
		interrupts = <0x00 0x12 0x04>;
		clocks = <0x04 0x175 0x04 0x8c 0x04 0x8f>;
		clock-names = "phy_ref\0rx_esc\0tx_esc";
		assigned-clocks = <0x04 0x83>;
		assigned-clock-parents = <0x04 0x31>;
		assigned-clock-rates = <0x4c4b400>;
		phys = <0x31>;
		phy-names = "dphy";
		status = "disabled";

		port@0 {

			endpoint {
				remote-endpoint = <0x32>;
				phandle = <0x34>;
			};
		};
	};

	mipi_dsi@32E10000 {
		compatible = "fsl,imx8mm-mipi-dsi_drm\0fsl,imx8mq-mipi-dsi_drm";
		clocks = <0x04 0x174 0x04 0x175>;
		clock-names = "core\0phy_ref";
		assigned-clocks = <0x04 0xbd 0x04 0xbe>;
		assigned-clock-parents = <0x04 0x36 0x04 0x28>;
		assigned-clock-rates = <0xfdad680 0x2367b880>;
		src = <0x33>;
		mux-sel = <0x2c>;
		phys = <0x31>;
		phys-names = "dphy";
		status = "disabled";

		port@0 {

			endpoint {
				remote-endpoint = <0x34>;
				phandle = <0x32>;
			};
		};

		port@1 {

			endpoint {
				remote-endpoint = <0x35>;
				phandle = <0x30>;
			};
		};
	};

	vpu_h1@38320000 {
		compatible = "nxp,imx8mq-hantro-h1";
		reg = <0x00 0x38320000 0x00 0x10000>;
		reg-names = "regs_hantro_h1";
		interrupts = <0x00 0x1e 0x04>;
		interrupt-names = "irq_hantro_h1";
		clocks = <0x04 0x1ae>;
		clock-names = "clk_hantro_h1";
		power-domains = <0x36>;
		assigned-clocks = <0x04 0xcc>;
		assigned-clock-parents = <0x04 0x2b>;
		assigned-clock-rates = <0x23c34600>;
		status = "disabled";
	};

	vpu_g1@38300000 {
		compatible = "nxp,imx8mq-hantro";
		reg = <0x00 0x38300000 0x00 0x100000>;
		reg-names = "regs_hantro";
		interrupts = <0x00 0x07 0x04>;
		interrupt-names = "irq_hantro";
		clocks = <0x04 0x1ac 0x04 0x1b7>;
		clock-names = "clk_hantro\0clk_hantro_bus";
		assigned-clocks = <0x04 0x92 0x04 0x54>;
		assigned-clock-parents = <0x04 0x2b 0x04 0x38>;
		assigned-clock-rates = <0x23c34600 0x2faf0800>;
		power-domains = <0x37>;
		status = "disabled";
	};

	vpu_g2@38310000 {
		compatible = "nxp,imx8mq-hantro";
		reg = <0x00 0x38310000 0x00 0x100000>;
		reg-names = "regs_hantro";
		interrupts = <0x00 0x08 0x04>;
		interrupt-names = "irq_hantro";
		clocks = <0x04 0x1af 0x04 0x1b7>;
		clock-names = "clk_hantro\0clk_hantro_bus";
		assigned-clocks = <0x04 0x93 0x04 0x54>;
		assigned-clock-parents = <0x04 0x2b 0x04 0x38>;
		assigned-clock-rates = <0x23c34600 0x2faf0800>;
		power-domains = <0x38>;
		status = "disabled";
	};

	chosen {
		bootargs = "console=ttymxc1,115200 earlycon=ec_imx6q,0x30890000,115200";
		stdout-patch = "/serial@30890000";
	};

	regulator-usdhc2 {
		compatible = "regulator-fixed";
		regulator-name = "VSD_3V3";
		regulator-min-microvolt = <0x325aa0>;
		regulator-max-microvolt = <0x325aa0>;
		gpio = <0x39 0x13 0x00>;
		enable-active-high;
		startup-delay-us = <0x64>;
		off-on-delay-us = <0x2ee0>;
		phandle = <0x26>;
	};
};
