#!/usr/bin/env bash
# One command: C60 (SDP) -> mainline kernel + Debian (slot a) or stock (slot b).
#
# Paths and devices are configurable via the environment:
#   C60_FLASH_BIN  this repo's flash.bin        (default: ./flash.bin)
#   C60_BOOT_SEQ   UART boot-sequence helper     (default: alongside this script)
#   C60_UART_CAP   UART capture log, for the closing message (default: ./c60-uart.cap)
#   C60_TTY        UART device, honoured by the boot-sequence helper (default: /dev/ttyUSB0)
set -e
SLOT="${1:-a}"
FB="${C60_FLASH_BIN:-./flash.bin}"
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BOOT_SEQ="${C60_BOOT_SEQ:-$HERE/c60_boot_seq.py}"
UART_CAP="${C60_UART_CAP:-./c60-uart.cap}"
[ -f "$FB" ] || { echo "missing flash.bin: $FB (set C60_FLASH_BIN)"; exit 1; }
echo "[c60-boot] waiting for SDP..."; until lsusb | grep -q "1fc9:0134"; do sleep 1; done
echo "[c60-boot] uuu loading u-boot..."; uuu -b spl "$FB" >/dev/null 2>&1 &
sleep 3
echo "[c60-boot] driving slot $SLOT boot over UART..."
python3 "$BOOT_SEQ" "$SLOT"
echo "[c60-boot] done; console on $UART_CAP"
